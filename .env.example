# === Telegram Bot ===
# Token from @BotFather (required)
BOT_TOKEN=1234567890:AAReplaceMeWithYourRealToken

# === Database ===
# Local SQLite (default — just leave as is for local dev):
DATABASE_URL=sqlite+aiosqlite:///mafia.db
#
# On Render: do NOT set this manually. Render injects DATABASE_URL
# automatically from the linked PostgreSQL service. The app converts
# "postgres://" to "postgresql+asyncpg://" at runtime.

# === Web server (Render) ===
# Render injects PORT automatically. For local dev you can override:
PORT=8080

# === Optional ===
# Bot owner id for admin commands (leave 0 to disable)
ADMIN_ID=0
# Log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
